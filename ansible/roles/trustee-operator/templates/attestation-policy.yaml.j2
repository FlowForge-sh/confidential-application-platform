apiVersion: v1
kind: ConfigMap
metadata:
  name: attestation-policy
  namespace: {{ trustee_operator_namespace }}
data:
  default_cpu.rego: |
    package policy

    import rego.v1

    default executables := 33
    default hardware := 97
    default configuration := 36
    default file_system := 0
    default instance_identity := 0
    default runtime_opaque := 0
    default storage_opaque := 0
    default sourced_data := 0

    trust_claims := {
      "executables": executables,
      "hardware": hardware,
      "configuration": configuration,
      "file-system": file_system,
      "instance-identity": instance_identity,
      "runtime-opaque": runtime_opaque,
      "storage-opaque": storage_opaque,
      "sourced-data": sourced_data,
    }

    # Fail-closed SNP allowlists:
    # Key release is granted only when both launch measurement and reported TCB
    # are explicitly in approved sets.
    allowed_snp_launch_measurements := [{% for v in trustee_snp_allowed_measurements %}"{{ v | lower }}"{% if not loop.last %}, {% endif %}{% endfor %}]
    allowed_snp_tcb_bootloader := [{% for v in trustee_snp_allowed_tcb_bootloader %}{{ v }}{% if not loop.last %}, {% endif %}{% endfor %}]
    allowed_snp_tcb_microcode := [{% for v in trustee_snp_allowed_tcb_microcode %}{{ v }}{% if not loop.last %}, {% endif %}{% endfor %}]
    allowed_snp_tcb_snp := [{% for v in trustee_snp_allowed_tcb_snp %}{{ v }}{% if not loop.last %}, {% endif %}{% endfor %}]
    allowed_snp_tcb_tee := [{% for v in trustee_snp_allowed_tcb_tee %}{{ v }}{% if not loop.last %}, {% endif %}{% endfor %}]
    allowed_snp_container_images := [{% for v in trustee_snp_allowed_container_images %}"{{ v | lower }}"{% if not loop.last %}, {% endif %}{% endfor %}]
    allowed_snp_init_data_hashes := [{% for v in trustee_snp_allowed_init_data_hashes %}"{{ v | lower }}"{% if not loop.last %}, {% endif %}{% endfor %}]

    snp_measurement_allowlisted if {
      input.snp
      lower(input.snp.measurement) in allowed_snp_launch_measurements
    }

    container_image_name(container) := image if {
      image := container["OCI"]["Annotations"]["io.kubernetes.cri.image-name"]
      is_string(image)
      image != ""
    }

    container_image_name(container) := image if {
      image := container["image_name"]
      is_string(image)
      image != ""
    }

    snp_container_images contains img if {
      container := input["init_data_claims"]["agent_policy_claims"]["containers"][_]
      img := lower(container_image_name(container))
    }

    snp_container_images contains img if {
      container := input["submods"]["cpu0"]["ear.veraison.annotated-evidence.init_data_claims"]["agent_policy_claims"]["containers"][_]
      img := lower(container_image_name(container))
    }

    snp_container_images contains img if {
      container := input["submods"]["cpu0"]["ear.veraison.annotated-evidence"]["init_data_claims"]["agent_policy_claims"]["containers"][_]
      img := lower(container_image_name(container))
    }

    snp_container_images_present if {
      count(snp_container_images) > 0
    }

    snp_container_image_disallowed if {
      img := snp_container_images[_]
      not img in allowed_snp_container_images
    }

    snp_container_images_valid if {
      not snp_container_images_present
    }

    snp_container_images_valid if {
      snp_container_images_present
      not snp_container_image_disallowed
    }

    snp_init_data_hashes contains hash if {
      raw := input["init_data"]
      is_string(raw)
      raw != ""
      hash := lower(raw)
    }

    snp_init_data_hashes contains hash if {
      raw := input["submods"]["cpu0"]["ear.veraison.annotated-evidence.init_data"]
      is_string(raw)
      raw != ""
      hash := lower(raw)
    }

    snp_init_data_hashes contains hash if {
      raw := input["submods"]["cpu0"]["ear.veraison.annotated-evidence"]["init_data"]
      is_string(raw)
      raw != ""
      hash := lower(raw)
    }

    snp_init_data_hashes_present if {
      count(snp_init_data_hashes) > 0
    }

    snp_init_data_hash_disallowed if {
      hash := snp_init_data_hashes[_]
      not hash in allowed_snp_init_data_hashes
    }

    snp_init_data_hashes_valid if {
      not snp_init_data_hashes_present
    }

    snp_init_data_hashes_valid if {
      snp_init_data_hashes_present
      not snp_init_data_hash_disallowed
    }

    snp_identity_present if {
      snp_container_images_present
    }

    snp_identity_present if {
      snp_init_data_hashes_present
    }

    # Fail-closed identity binding:
    # - at least one identity source must be present
    # - any present identity source must be allowlisted
    snp_workload_identity_allowlisted if {
      snp_identity_present
      snp_container_images_valid
      snp_init_data_hashes_valid
    }

    executables := 3 if {
      input.snp
      snp_measurement_allowlisted
      snp_workload_identity_allowlisted
    }

    hardware := 2 if {
      input.snp
      snp_measurement_allowlisted
      snp_workload_identity_allowlisted
      input.snp.reported_tcb_bootloader in allowed_snp_tcb_bootloader
      input.snp.reported_tcb_microcode in allowed_snp_tcb_microcode
      input.snp.reported_tcb_snp in allowed_snp_tcb_snp
      input.snp.reported_tcb_tee in allowed_snp_tcb_tee
    }

    configuration := 2 if {
      input.snp
      snp_measurement_allowlisted
      snp_workload_identity_allowlisted
      input.snp.policy_debug_allowed == false
      input.snp.policy_migrate_ma == false
    }
