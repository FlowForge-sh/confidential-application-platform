---
# Allow Caddy (reverse proxy) to reach Flux UI (Capacitor) on port 9000.
# Flux's allow-egress policy only allows ingress from within flux-system; this adds an exception for caddy namespace.
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: allow-caddy-to-capacitor
  namespace: {{ flux_ui_namespace }}
  labels:
    app.kubernetes.io/name: capacitor
    app.kubernetes.io/component: network-policy
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/instance: capacitor
  policyTypes:
    - Ingress
  ingress:
    - from:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: caddy
      ports:
        - protocol: TCP
          port: 9000
