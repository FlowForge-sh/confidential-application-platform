# Tetragon Helm values - overrides only (chart defaults for the rest).
# Chart: https://github.com/cilium/tetragon/tree/main/install/kubernetes/tetragon
# Docs: https://tetragon.io/docs/reference/helm-chart/

# CRI: required for pod/container association on K3s
tetragon:
  cri:
    enabled: {{ tetragon_cri_enabled | default(true) }}
    socketHostPath: "{{ tetragon_cri_socket_host_path | default('/run/k3s/containerd/containerd.sock') }}"
  # Process credentials (SUID, file caps, fileless/deleted binary observability)
  enableProcessCred: {{ tetragon_enable_process_cred | default(true) }}
  prometheus:
    enabled: {{ tetragon_prometheus_enabled | default(true) }}
    serviceMonitor:
      enabled: {{ tetragon_prometheus_service_monitor_enabled | default(true) }}

tetragonOperator:
  prometheus:
    enabled: {{ tetragon_prometheus_enabled | default(true) }}
    serviceMonitor:
      enabled: {{ tetragon_operator_prometheus_service_monitor_enabled | default(true) }}

{# Optional: file export to host path for Promtail file scrape #}
{% if tetragon_export_mode | default('stdout') == 'file' %}
# Export JSON events to host path (Promtail can scrape this file)
exportDirectory: "{{ tetragon_export_host_path | default('/var/log/tetragon') }}"
extraHostPathMounts:
  - name: tetragon-export
    mountPath: "{{ tetragon_export_host_path | default('/var/log/tetragon') }}"
    path: "{{ tetragon_export_host_path | default('/var/log/tetragon') }}"
    type: DirectoryOrCreate
tetragon:
  exportFilename: "tetragon.log"
{% endif %}
