{% if caddy_use_persistent_storage | default(false) %}
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: caddy-data
  namespace: "{{ caddy_namespace }}"
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 1Gi
{% if caddy_data_storage_class | length > 0 %}
  storageClassName: "{{ caddy_data_storage_class }}"
{% endif %}
---
{% endif %}
apiVersion: apps/v1
kind: Deployment
metadata:
  name: caddy
  namespace: "{{ caddy_namespace }}"
  labels:
    app: caddy
spec:
  replicas: {{ caddy_replicas }}
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: caddy
  template:
    metadata:
      labels:
        app: caddy
        # Caddy config (for visibility / label-driven setups); token is from Secret, not stored here
        caddy.tls.resolvers: "1.1.1.1"
        caddy.tls.dns: "cloudflare"
        caddy.tls.dns.api_token: "set"
      annotations:
        # Host(s) Caddy serves (from caddy_routes)
        caddy.hosts: "{{ caddy_routes | map(attribute='host') | join(',') }}"
    spec:
      # Use pod network (not hostNetwork) so Cilium sees traffic from caddy namespace;
      # tenant policies can allow "from caddy namespace" to backend ports (e.g. flowforge enclava:8000).
      hostNetwork: false
      # Run Caddy on the control plane node. hostPort 443 so traffic to master:443 reaches Caddy;
      # egress from the pod still uses the pod network, so Cilium "from caddy namespace" policies apply.
      affinity:
        nodeAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
              - matchExpressions:
                  - key: node-role.kubernetes.io/control-plane
                    operator: In
                    values: ["true"]
      tolerations:
        - key: node-role.kubernetes.io/master
          operator: Exists
          effect: NoSchedule
        - key: node-role.kubernetes.io/control-plane
          operator: Exists
          effect: NoSchedule
      containers:
        - name: caddy
          image: "{{ caddy_image }}"
          imagePullPolicy: Never   # Use locally built image (docker build + k3s ctr images import on control plane)
          command:
            - caddy
            - run
            - --config
            - /etc/caddy/Caddyfile
          ports:
            - containerPort: 443
              hostPort: 443
              name: https
          env:
{% for zone in cloudflare_tokens.keys() %}
            - name: CF_API_TOKEN_{{ zone | replace('.', '_') | upper }}
              valueFrom:
                secretKeyRef:
                  name: caddy-cloudflare-token
                  key: api_token_{{ zone | replace('.', '_') }}
{% endfor %}
            - name: XDG_DATA_HOME
              value: /data/caddy
          volumeMounts:
            - name: caddyfile
              mountPath: /etc/caddy
              readOnly: true
            - name: caddy-data
              mountPath: /data
          resources:
            requests:
              cpu: 50m
              memory: 64Mi
            limits:
              cpu: 500m
              memory: 256Mi
          securityContext:
            capabilities:
              drop: [ALL]
              add: [NET_BIND_SERVICE]
            readOnlyRootFilesystem: false
            runAsNonRoot: false
            runAsUser: 0
      volumes:
        - name: caddyfile
          configMap:
            name: caddyfile
        - name: caddy-data
{% if caddy_use_persistent_storage | default(false) %}
          persistentVolumeClaim:
            claimName: caddy-data
{% else %}
          emptyDir: {}
{% endif %}
---
apiVersion: v1
kind: Service
metadata:
  name: caddy
  namespace: "{{ caddy_namespace }}"
  labels:
    app: caddy
spec:
  type: LoadBalancer
{% if caddy_external_ips is defined and caddy_external_ips | length > 0 %}
  externalIPs: {{ caddy_external_ips | to_json }}
{% endif %}
  ports:
    - port: 443
      targetPort: 443
      protocol: TCP
      name: https
  selector:
    app: caddy
