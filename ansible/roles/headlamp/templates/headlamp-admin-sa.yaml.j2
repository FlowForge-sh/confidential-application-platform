apiVersion: v1
kind: ServiceAccount
metadata:
  name: headlamp-admin
  namespace: "{{ headlamp_namespace }}"
---
# Named headlamp-auto-login-admin to avoid conflict with Headlamp chart's headlamp-admin ClusterRoleBinding
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: headlamp-auto-login-admin
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: cluster-admin
subjects:
  - kind: ServiceAccount
    name: headlamp-admin
    namespace: "{{ headlamp_namespace }}"
{% if headlamp_admin_sa_legacy_kube_system_binding | default(true) %}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: headlamp-auto-login-admin-kube-system
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: cluster-admin
subjects:
  - kind: ServiceAccount
    name: headlamp-admin
    namespace: kube-system
{% endif %}
